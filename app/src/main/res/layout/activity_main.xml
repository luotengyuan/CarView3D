<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        style="@style/Widget.CarView3D.Toolbar"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        app:titleCentered="true"
        app:titleTextAppearance="@style/TextAppearance.CarView3D.ToolbarTitleSmall" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <Button
            android:id="@+id/btnPictureMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/picture_mode" />

        <Button
            android:id="@+id/btnVideoMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/video_mode" />
    </LinearLayout>

</LinearLayout>
